VITE_GUESTY_PROXY_URL=/api/guesty

# Server-side only. Do not expose these as VITE_ variables.
GUESTY_API_MODE=booking
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=
GUESTY_DEFAULT_COUNTRY=United States
GUESTY_ALLOWED_ORIGIN=https://www.vacationrentalexpertz.com

# JSON array of combo groups. Keep this on one line in most hosting dashboards.
GUESTY_COMBO_GROUPS=[{"id":"azure-six-bedroom","title":"Azure Resort 6-Bedroom Pairing","resort":"Azure Resort","location":"Miramar Beach, Florida","badge":"Two 3BR condos","memberIds":["GUESTY_LISTING_ID_A","GUESTY_LISTING_ID_B"],"summary":"Two nearby condos in the same resort, packaged for large families.","description":"This combo is one guest-facing stay made from two separate nearby units.","image":"https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=1400&q=82"}]
