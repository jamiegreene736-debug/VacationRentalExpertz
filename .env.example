VITE_GUESTY_PROXY_URL=/api/guesty

# Server-side only. Do not expose these as VITE_ variables.
GUESTY_API_MODE=booking
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=
GUESTY_DEFAULT_COUNTRY=United States
GUESTY_ALLOWED_ORIGIN=https://www.vacationrentalexpertz.com

# Optional: if your Guesty account also contains non-combined listings, limit
# the website to only your already-combined public listings.
GUESTY_LISTING_IDS=
GUESTY_LISTING_TAG=
