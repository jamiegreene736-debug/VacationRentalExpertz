VITE_GUESTY_PROXY_URL=/api/guesty

# Server-side only. Do not expose these as VITE_ variables.
# auto tries Open API first, then Booking Engine API. You can also use open or booking.
GUESTY_API_MODE=auto

# Preferred when this site needs its own Booking Engine credentials.
GUESTY_BOOKING_CLIENT_ID=
GUESTY_BOOKING_CLIENT_SECRET=

# Optional Open API-specific names, if using GUESTY_API_MODE=open.
GUESTY_OPEN_CLIENT_ID=
GUESTY_OPEN_CLIENT_SECRET=

# Backward-compatible fallback names. Do not use these if another app in the
# same Railway service already depends on different Guesty credentials.
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=
GUESTY_DEFAULT_COUNTRY=United States
GUESTY_ALLOWED_ORIGIN=https://www.vacationrentalexpertz.com

# Optional: if your Guesty account also contains non-combined listings, limit
# the website to only your already-combined public listings.
GUESTY_LISTING_IDS=
GUESTY_LISTING_TAG=
GUESTY_VIEW_ID=

# Optional. Used when Guesty listings do not include their own booking URL.
# Example: https://book.example.com/listing/{listingId}
GUESTY_BOOKING_URL_TEMPLATE=
